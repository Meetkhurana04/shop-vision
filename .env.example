# ─────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# A long random string used to sign JWT tokens.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# How long login sessions last (in minutes). 480 = 8 hours.
ACCESS_TOKEN_EXPIRE_MINUTES=480

# The SQLite database file path (relative to project root)
DATABASE_URL=sqlite:///./shopvision.db

# Set to "development" or "production"
APP_ENV=development

# App display name shown in the browser tab and navbar
APP_NAME=Shopvision
